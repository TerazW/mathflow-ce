# MathFlow Community Edition — Environment Variables

# Frontend
VITE_API_URL=http://localhost:3001

# Backend
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mathflow

# Authentication (required — generate a random 32+ character string)
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters

# AI features use BYOK (Bring Your Own Key)
# Configure your API key in the app's Settings panel — no server-side keys needed
